# Environment Variables for Frontend Application
# Copy this file to .env and update the values as needed

# Backend API URL - used for development and iframe embeds
VITE_WEBSITE_DOMAIN=http://localhost:8000

# Email verification settings
VITE_EMAIL_VERIFICATION=disable

# Authentication mode
VITE_AUTH_MODE=enabled

# PostHog analytics API key
VITE_POSTHOG_API_KEY=
